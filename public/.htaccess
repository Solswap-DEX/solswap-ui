Options -MultiViews
DirectoryIndex index.html
RewriteEngine On

# Removed redirect to /swap/ so Radar acts as landing page

# If the request matches a real file, serve it
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# If the request matches a real directory (e.g. /bridge/), let Apache serve its index.html
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Let /api/ paths pass through to Apache ProxyPass (bypass SPA fallback)
RewriteCond %{REQUEST_URI} ^/api/
RewriteRule ^ - [L]

# Everything else falls back to root index.html (true SPA routes only)
RewriteRule ^ index.html [L]
